<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.layout.MainLayoutController">

    <!-- Barra superior -->
    <top>
        <HBox alignment="CENTER_RIGHT" prefHeight="60" spacing="20" styleClass="header">

            <padding>
                <Insets bottom="10" left="10" right="10" top="10" />
            </padding>

            <Label styleClass="header-title" text="NBA Predictor" HBox.hgrow="ALWAYS" />

            <Label fx:id="lblUser" styleClass="header-label" text="Usuario" />

            <Label fx:id="lblPoints" styleClass="header-label" text="Puntos: 1000" />

            <Button onAction="#handleLogout" text="Cerrar sesión" />
        </HBox>
    </top>

    <!-- Menú lateral fijo -->
    <left>
        <VBox alignment="TOP_CENTER" maxWidth="220" minWidth="220" prefWidth="220" spacing="10" styleClass="sidebar">

            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>

            <Button maxWidth="Infinity" onAction="#loadDashboard" text="🏠 Dashboard" />
            <Button maxWidth="Infinity" onAction="#loadMatches" text="📅 Partidos" />
            <Button maxWidth="Infinity" onAction="#loadStatistics" text="📊 Estadísticas" />
            <Button maxWidth="Infinity" onAction="#loadBets" text="💰 Apuestas" />
            <Button maxWidth="Infinity" onAction="#loadRankings" text="🏆 Rankings" />
            <Button maxWidth="Infinity" onAction="#loadProfile" text="👤 Mi Perfil" />

            <Separator />

            <Button fx:id="btnAdmin" managed="false" maxWidth="Infinity" onAction="#loadAdmin" styleClass="admin-button" text="⚙ Administración" visible="false" />
        </VBox>
    </left>

    <!-- Contenido principal que crece -->
    <center>
        <StackPane fx:id="contentPane" styleClass="content" HBox.hgrow="ALWAYS" VBox.vgrow="ALWAYS" />
    </center>

</BorderPane>
